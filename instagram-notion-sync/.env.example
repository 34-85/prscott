# ─────────────────────────────────────────────────────────────────────────
# Instagram → Notion sync configuration
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# ─────────────────────────────────────────────────────────────────────────

# ── Instagram session cookies ────────────────────────────────────────────
# Log into instagram.com in your browser, open DevTools → Application →
# Cookies → https://www.instagram.com, and copy these three values.
#
# Option A — individual cookies (recommended):
IG_SESSIONID=
IG_DS_USER_ID=
IG_CSRFTOKEN=
#
# Option B — paste the whole Cookie header instead (leave A blank if you use this):
# IG_COOKIE=sessionid=...; ds_user_id=...; csrftoken=...
#
# Advanced (usually leave as-is):
# IG_APP_ID=936619743392459
# IG_USER_AGENT=Mozilla/5.0 ...

# ── Notion ───────────────────────────────────────────────────────────────
# Create an internal integration at https://www.notion.so/my-integrations,
# copy its secret here, and share your target page/database with it.
NOTION_TOKEN=

# EITHER point at an existing "Instagram Saves" database…
NOTION_SAVES_DB_ID=
# …OR give a parent page ID and the script creates the database on first run
# (the resulting database ID is remembered in state.json).
NOTION_PARENT_PAGE_ID=

# ── Runtime (optional) ───────────────────────────────────────────────────
# Where to keep the dedup state file (default: ./state.json next to the code).
# SYNC_STATE_PATH=/Users/you/.instagram-notion-sync/state.json
# Seconds to wait between Instagram requests (be gentle to avoid rate limits).
# SYNC_REQUEST_DELAY=1.5
